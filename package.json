{
  "name": "perkup",
  "version": "2.0.0",
  "private": true,
  "description": "PerkUp - Coffee loyalty ecosystem",
  "scripts": {
    "dev:server": "npm run dev --prefix server",
    "dev:bot": "npm run dev --prefix bot",
    "dev:client": "npm run dev --prefix client",
    "install:all": "npm install --prefix server && npm install --prefix bot && npm install --prefix client",
    "db:generate": "npm run db:generate --prefix server",
    "db:push": "npm run db:push --prefix server",
    "db:migrate": "npm run db:migrate --prefix server",
    "db:seed": "npm run db:seed --prefix server",
    "db:studio": "npm run db:studio --prefix server",
    "build": "npm install --prefix server && npm run build --prefix server && rm -rf dist && cp -R server/dist dist",
    "start": "NODE_PATH=server/node_modules node dist/index.js"
  },
  "keywords": [
    "telegram",
    "mini-app",
    "coffee",
    "fastify",
    "prisma"
  ],
  "license": "MIT"
}
