generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 芒聰聙芒聰聙芒聰聙 ENUMS 芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙

enum Role {
  USER
  BARISTA
  ADMIN
  OWNER
}

enum OrderStatus {
  PAYMENT_PENDING
  PENDING
  SENT_TO_POS
  ACCEPTED
  PREPARING
  READY
  COMPLETED
  CANCELLED
  AUTO_EXPIRED
  UNASSIGNED
}

enum GameType {
  TIC_TAC_TOE
  PERKIE_CATCH
  BARISTA_RUSH
  MEMORY_COFFEE
  PERKIE_JUMP
}

enum TransactionType {
  SPIN
  ORDER
  REFERRAL
  REDEEM
  GAME
  BIRTHDAY
  BONUS
  EXPIRED
  ADMIN
}

enum PendingLoyaltyStatus {
  PENDING
  CLAIMED
  EXPIRED
}

enum CommunityChannel {
  GENERAL
  BOARD_GAMES
  MOVIE_NIGHTS
}

enum CommunityMessageStatus {
  VISIBLE
  HIDDEN
  DELETED_BY_USER
  DELETED_BY_ADMIN
}

enum BoardGameDifficulty {
  EASY
  MEDIUM
  HARD
}

enum BoardGameMeetupStatus {
  OPEN
  FULL
  CANCELLED
  COMPLETED
}

enum MeetupParticipantStatus {
  JOINED
  CANCELLED
  NO_SHOW
}

enum CommunityEventType {
  MOVIE_NIGHT
  BOARD_GAME_NIGHT
  MEETUP
  OTHER
}

enum CommunityEventStatus {
  DRAFT
  PUBLISHED
  CANCELLED
  COMPLETED
}

enum EventParticipantStatus {
  GOING
  MAYBE
  CANCELLED
  ATTENDED
  NO_SHOW
}

// 芒聰聙芒聰聙芒聰聙 USER 芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙

model User {
  id                  Int       @id @default(autoincrement())
  telegramId          BigInt    @unique
  username            String?
  firstName           String
  lastName            String?
  role                Role      @default(USER)
  points              Int       @default(0)
  level               String    @default("BRONZE")
  monthlyOrders       Int       @default(0)
  lastSpinDate        String?
  birthDate           DateTime?
  lastBirthdayBonus   Int?
  lastActivity        DateTime  @default(now())
  referredById        Int?
  referredBy          User?     @relation("Referrals", fields: [referredById], references: [id])
  referrals           User[]    @relation("Referrals")
  referralBonusPaid   Boolean   @default(false)
  preferredLocationId Int?
  phone               String?
  language            String    @default("uk")
  noShowCount         Int       @default(0)
  cashPaymentBlocked  Boolean   @default(false)
  notifSpin           Boolean   @default(true)
  notifWinback        Boolean   @default(true)
  notifMorning        Boolean   @default(true)
  notifPromo          Boolean   @default(true)
  onboardingDone      Boolean   @default(false)
  radioGenre          String?
  isActive            Boolean   @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  orders              Order[]
  shifts              Shift[]
  transactions        PointsTransaction[]
  redemptions         RedemptionCode[]
  gameSessions        GameSession[]
  tips                Tip[]
  reviews             Review[]
  claimedPendingLoyaltyEvents PendingLoyaltyEvent[]
  communityMessages   CommunityMessage[]
  boardGameMeetups    BoardGameMeetup[]
  boardGameMeetupParticipants BoardGameMeetupParticipant[]
  communityEventsCreated CommunityEvent[] @relation("CommunityEventCreator")
  communityEventParticipants CommunityEventParticipant[]
  movieVotes          MovieVote[]

  @@index([telegramId])
  @@index([role])
  @@index([lastActivity])
}

// 芒聰聙芒聰聙芒聰聙 LOCATION 芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙

model Location {
  id                  Int      @id @default(autoincrement())
  slug                String   @unique
  name                String
  address             String
  lat                 Float
  lng                 Float
  radius              Int      @default(100)
  allowOrders         Boolean  @default(false)
  hasPoster           Boolean  @default(false)
  menuCategories      Json?
  posterSubdomain     String?
  posterAccount       String?
  posterToken         String?
  posterSpotId        Int?
  googlePlaceId       String?
  googleMapsUrl       String?
  busyMode            Boolean  @default(false)
  busyModeUntil       DateTime?
  maxQueueSize        Int      @default(10)
  hasPrinter          Boolean  @default(false)
  printerIp           String?
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  products            Product[]
  bundles             Bundle[]
  orders              Order[]
  shifts              Shift[]
  workingHours        WorkingHours[]
  reviews             Review[]
  pendingLoyaltyEvents PendingLoyaltyEvent[]
  boardGameMeetups    BoardGameMeetup[]
  communityEvents     CommunityEvent[]

  @@index([slug])
}

model WorkingHours {
  id          Int      @id @default(autoincrement())
  locationId  Int
  dayOfWeek   Int      // 0=Sun, 1=Mon ... 6=Sat
  openTime    String   // "08:00"
  closeTime   String   // "22:00"
  isClosed    Boolean  @default(false)
  location    Location @relation(fields: [locationId], references: [id])

  @@unique([locationId, dayOfWeek])
}

// 芒聰聙芒聰聙芒聰聙 PRODUCT 芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙

model Product {
  id              Int      @id @default(autoincrement())
  locationId      Int
  posterProductId String?
  name            String
  description     String?
  ingredients     String?
  price           Decimal  @db.Decimal(10, 2)
  category        String
  telegramFileId  String?
  imageUrl        String?
  posterImageUrl  String?
  isNew           Boolean  @default(false)
  isTop           Boolean  @default(false)
  isSeasonal      Boolean  @default(false)
  isRecommended   Boolean  @default(false)
  isHiddenInApp   Boolean  @default(false)
  calories        Int?
  volume          String?
  allergens       String[] @default([])
  tags            String[] @default([])
  modifiers       Json?
  isAvailable     Boolean  @default(true)
  ordersCount     Int      @default(0)
  categoryOrder   Int      @default(0)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  location        Location    @relation(fields: [locationId], references: [id])
  orderItems      OrderItem[]
  bundleItems     BundleItem[]

  @@index([locationId, category, isAvailable])
  @@index([locationId, ordersCount])
  @@unique([locationId, posterProductId])
}

model PendingLoyaltyEvent {
  id                 String               @id @default(cuid())
  phone              String
  locationId         Int?
  posterAccountId    String?
  posterTransactionId String
  totalAmount        Int
  points             Int
  status             PendingLoyaltyStatus @default(PENDING)
  expiresAt          DateTime?
  claimedByUserId    Int?
  claimedAt          DateTime?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  location           Location?            @relation(fields: [locationId], references: [id])
  claimedByUser      User?                @relation(fields: [claimedByUserId], references: [id])

  @@unique([posterAccountId, posterTransactionId])
  @@index([phone])
  @@index([status])
}

model CommunityMessage {
  id         String                 @id @default(cuid())
  userId     Int
  channel    CommunityChannel
  text       String
  status     CommunityMessageStatus @default(VISIBLE)
  replyToId  String?
  createdAt  DateTime               @default(now())
  updatedAt  DateTime               @updatedAt

  user       User                   @relation(fields: [userId], references: [id])
  replyTo    CommunityMessage?      @relation("CommunityReply", fields: [replyToId], references: [id])
  replies    CommunityMessage[]     @relation("CommunityReply")

  @@index([channel, createdAt])
  @@index([userId])
  @@index([status])
}

model BoardGame {
  id             String              @id @default(cuid())
  title          String              @unique
  description    String?
  imageUrl       String?
  minPlayers     Int?
  maxPlayers     Int?
  avgDurationMin Int?
  difficulty     BoardGameDifficulty?
  isAvailable    Boolean             @default(true)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  meetups        BoardGameMeetup[]

  @@index([isAvailable])
}

model BoardGameMeetup {
  id          String                @id @default(cuid())
  gameId       String?
  creatorId    Int
  locationId   Int?
  title        String
  description  String?
  startsAt     DateTime
  maxPlayers   Int
  status       BoardGameMeetupStatus @default(OPEN)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  game         BoardGame?           @relation(fields: [gameId], references: [id])
  creator      User                 @relation(fields: [creatorId], references: [id])
  location     Location?            @relation(fields: [locationId], references: [id])
  participants BoardGameMeetupParticipant[]

  @@index([startsAt])
  @@index([locationId])
  @@index([status])
  @@index([creatorId])
}

model BoardGameMeetupParticipant {
  id        String                   @id @default(cuid())
  meetupId  String
  userId    Int
  status    MeetupParticipantStatus  @default(JOINED)
  createdAt DateTime                 @default(now())

  meetup    BoardGameMeetup          @relation(fields: [meetupId], references: [id])
  user      User                     @relation(fields: [userId], references: [id])

  @@unique([meetupId, userId])
  @@index([userId])
  @@index([meetupId])
}

model CommunityEvent {
  id            String                @id @default(cuid())
  type          CommunityEventType
  title         String
  description   String?
  imageUrl      String?
  locationId    Int?
  startsAt      DateTime
  endsAt        DateTime?
  capacity      Int?
  status        CommunityEventStatus  @default(PUBLISHED)
  createdById   Int?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  location      Location?             @relation(fields: [locationId], references: [id])
  createdBy     User?                 @relation("CommunityEventCreator", fields: [createdById], references: [id])
  participants  CommunityEventParticipant[]
  movieOptions  MovieOption[]
  movieVotes    MovieVote[]

  @@index([type, startsAt])
  @@index([locationId])
  @@index([status])
}

model CommunityEventParticipant {
  id        String                 @id @default(cuid())
  eventId   String
  userId    Int
  status    EventParticipantStatus @default(GOING)
  createdAt DateTime               @default(now())

  event     CommunityEvent         @relation(fields: [eventId], references: [id])
  user      User                   @relation(fields: [userId], references: [id])

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
}

model MovieOption {
  id          String           @id @default(cuid())
  eventId     String
  title       String
  description String?
  posterUrl   String?
  sortOrder   Int              @default(0)
  createdAt   DateTime         @default(now())

  event       CommunityEvent   @relation(fields: [eventId], references: [id])
  votes       MovieVote[]

  @@index([eventId])
}

model MovieVote {
  id        String         @id @default(cuid())
  eventId   String
  optionId  String
  userId    Int
  createdAt DateTime       @default(now())

  event     CommunityEvent @relation(fields: [eventId], references: [id])
  option    MovieOption    @relation(fields: [optionId], references: [id])
  user      User           @relation(fields: [userId], references: [id])

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([optionId])
}

// 芒聰聙芒聰聙芒聰聙 BUNDLE 芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙

model Bundle {
  id             Int          @id @default(autoincrement())
  locationId     Int
  name           String
  description    String?
  price          Decimal      @db.Decimal(10, 2)
  originalPrice  Decimal      @db.Decimal(10, 2)
  discountPct    Int
  telegramFileId String?
  imageUrl       String?
  isAvailable    Boolean      @default(true)
  sortOrder      Int          @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  location       Location     @relation(fields: [locationId], references: [id])
  items          BundleItem[]
  orderItems     OrderItem[]
}

model BundleItem {
  id        Int     @id @default(autoincrement())
  bundleId  Int
  productId Int
  quantity  Int     @default(1)

  bundle    Bundle  @relation(fields: [bundleId], references: [id])
  product   Product @relation(fields: [productId], references: [id])
}

// 芒聰聙芒聰聙芒聰聙 ORDER 芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙

model Order {
  id             Int         @id @default(autoincrement())
  userId         Int
  locationId     Int
  shiftId        Int?
  status         OrderStatus @default(PAYMENT_PENDING)
  posterOrderId  Int?
  total          Decimal     @db.Decimal(10, 2)
  discount       Decimal     @default(0) @db.Decimal(10, 2)
  promoCode      String?
  paymentMethod  String      @default("cash")
  paymentId      String?
  pointsUsed     Int         @default(0)
  pickupTime     DateTime?
  estimatedReady DateTime?
  qrCode         String?     @unique
  comment        String?
  isRepeat       Boolean     @default(false)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  user           User        @relation(fields: [userId], references: [id])
  location       Location    @relation(fields: [locationId], references: [id])
  shift          Shift?      @relation(fields: [shiftId], references: [id])
  items          OrderItem[]
  review         Review?
  tip            Tip?

  @@index([userId, createdAt])
  @@index([locationId, status])
  @@index([shiftId])
}

model OrderItem {
  id         Int      @id @default(autoincrement())
  orderId    Int
  productId  Int?
  bundleId   Int?
  name       String
  price      Decimal  @db.Decimal(10, 2)
  quantity   Int      @default(1)
  modifiers  Json?

  order      Order    @relation(fields: [orderId], references: [id])
  product    Product? @relation(fields: [productId], references: [id])
  bundle     Bundle?  @relation(fields: [bundleId], references: [id])
}

// 芒聰聙芒聰聙芒聰聙 SHIFT 芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙

model Shift {
  id          Int       @id @default(autoincrement())
  userId      Int
  locationId  Int
  startedAt   DateTime  @default(now())
  endedAt     DateTime?
  ordersCount Int       @default(0)
  avgRating   Float?
  totalTips   Decimal   @default(0) @db.Decimal(10, 2)

  user        User      @relation(fields: [userId], references: [id])
  location    Location  @relation(fields: [locationId], references: [id])
  orders      Order[]
  tips        Tip[]

  @@index([locationId, endedAt])
  @@index([userId, startedAt])
}

// 芒聰聙芒聰聙芒聰聙 LOYALTY 芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙

model PointsTransaction {
  id              Int             @id @default(autoincrement())
  userId          Int
  amount          Int
  type            TransactionType
  description     String
  idempotencyKey  String          @unique
  createdAt       DateTime        @default(now())

  user            User            @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([type])
}

model RedemptionCode {
  id        Int       @id @default(autoincrement())
  userId    Int
  code      String    @unique
  points    Int
  usedAt    DateTime?
  expiresAt DateTime
  createdAt DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id])

  @@index([code])
  @@index([expiresAt])
}

// 芒聰聙芒聰聙芒聰聙 PROMO 芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙

model Promo {
  id          Int       @id @default(autoincrement())
  code        String    @unique
  type        String    // "PERCENT" | "FIXED" | "POINTS"
  value       Decimal   @db.Decimal(10, 2)
  locationId  Int?
  maxUses     Int?
  usedCount   Int       @default(0)
  minOrderSum Decimal?  @db.Decimal(10, 2)
  expiresAt   DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())

  @@index([code, isActive])
}

// 芒聰聙芒聰聙芒聰聙 REVIEW 芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙芒聰聙

model Review {
