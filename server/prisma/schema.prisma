generator client {  provider = "prisma-client-js"}datasource db {  provider = "postgresql"  url      = env("DATABASE_URL")}// ─── ENUMS ────────────────────────────────────────────────────────enum Role {  USER  BARISTA  ADMIN  OWNER}enum OrderStatus {  PAYMENT_PENDING  PENDING  ACCEPTED  PREPARING  READY  COMPLETED  CANCELLED  AUTO_EXPIRED  UNASSIGNED}enum GameType {  TIC_TAC_TOE  PERKIE_CATCH  BARISTA_RUSH  MEMORY_COFFEE  PERKIE_JUMP

model RadioTrack {
  id        Int      @id @default(autoincrement())
  fileId    String
  title     String
  artist    String   @default("PerkUp Radio")
  duration  Int      @default(180)
  genre     String   @default("lofi")
  url       String
  position  Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([genre])
  @@index([position])
}
